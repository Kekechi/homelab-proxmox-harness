# =============================================================================
# production.tfvars.example — Production Environment
#
# Copy to production.tfvars on the OPERATOR'S WORKSTATION (not in dev container).
# production.tfvars is gitignored — never commit it.
#
# IMPORTANT: Claude Code MUST NOT apply production.
#   Plan only from dev container:
#     terraform init -backend-config="bucket=tfstate-production" ...
#     terraform plan -var-file=production.tfvars -out=production.tfplan
#   Operator applies from their workstation:
#     terraform apply production.tfplan
# =============================================================================

proxmox_node = "pve"

# Production pool (set to "" if no pool isolation is used for production)
pool_id = ""

datastore_id      = "local-lvm"
bridge            = "vmbr0"
vm_id_range_start = 100
clone_template_id = 0
ssh_public_key    = "ssh-ed25519 AAAAC3... your-key-comment"
