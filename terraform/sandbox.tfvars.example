# =============================================================================
# sandbox.tfvars.example — Sandbox Environment
#
# Copy to sandbox.tfvars and fill in your actual values.
# sandbox.tfvars is gitignored — never commit it.
#
# Apply workflow (Claude Code):
#   terraform init -backend-config="bucket=tfstate-sandbox" ...
#   terraform plan -var-file=sandbox.tfvars -out=sandbox.tfplan
#   terraform apply sandbox.tfplan
# =============================================================================

# Proxmox node name (Proxmox UI > Datacenter > your node)
proxmox_node = "pve"

# Sandbox resource pool (must exist — see docs/proxmox-iam.md)
# Claude's token (terraform@pve!claude-sandbox) has ACL only on /pool/sandbox
pool_id = "sandbox"

# Storage for VM/LXC disks
# Common values: "local-lvm", "local-zfs", "ceph"
datastore_id = "local-lvm"

# Network bridge for sandbox VMs
bridge = "vmbr0"

# VLAN tag for sandbox network (null = untagged)
vlan_id = 20

# Sandbox network CIDR — must match .devcontainer/squid/allowed-cidrs.conf
network_cidr = "192.168.20.0/24"

# Starting VM ID for sandbox resources (must not conflict with existing VMs)
vm_id_range_start = 200

# VM template to clone from (0 = no cloning, create from scratch)
clone_template_id = 0

# SSH public key for cloud-init injection
ssh_public_key = "ssh-ed25519 AAAAC3... your-key-comment"
