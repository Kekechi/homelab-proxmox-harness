# Squid proxy image with ACL config baked in.
#
# IMPORTANT: squid.conf and allowed-cidrs.conf are baked into this image
# at build time — they are NOT mounted from the workspace. This means
# Claude Code cannot modify the network policy at runtime.
#
# To update the allowed CIDR list or domains:
#   1. Edit .devcontainer/squid/allowed-cidrs.conf
#   2. Edit .devcontainer/squid/squid.conf.local     (personal domains) 
#   3. Run: docker compose build squid-proxy
#   4. Reopen the dev container

FROM ubuntu/squid:latest

COPY squid.conf /etc/squid/squid.conf
COPY allowed-cidrs.conf /etc/squid/allowed-cidrs.conf
COPY squid.conf.local     /etc/squid/squid.conf.local

# Validate config at build time — fails the build if squid.conf has errors
RUN squid -k parse -f /etc/squid/squid.conf
