# =============================================================================
# .envrc.example — reference for the .envrc generated by `make configure`
#
# WORKFLOW:
#   1. cp config/sandbox.yml.example config/sandbox.yml
#   2. Edit config/sandbox.yml with your Proxmox/MinIO endpoints
#   3. make configure        <- generates .envrc with non-secret values filled in
#   4. Fill in the 3 REPLACE_ME secrets in the generated .envrc
#   5. direnv allow
#
# `make configure` auto-populates PROXMOX_VE_ENDPOINT, PROXMOX_VE_INSECURE,
# and MINIO_ENDPOINT from config/<env>.yml.
# You only need to set the 3 secret values marked REPLACE_ME manually.
#
# NEVER commit .envrc -- it is gitignored
# =============================================================================

# Sandbox Proxmox (Claude Code may apply to this environment)
# Token name: terraform@pve!claude-sandbox | ACL: /pool/sandbox only
# See: docs/proxmox-iam.md for setup instructions
export PROXMOX_VE_ENDPOINT="https://192.168.X.X:8006/"   # auto-set by make configure
export PROXMOX_VE_API_TOKEN="terraform@pve!claude-sandbox=REPLACE_ME"
export PROXMOX_VE_INSECURE="true"                         # auto-set by make configure

# MinIO Terraform state backend (LXC on Proxmox). See: docs/minio-setup.md
# Claude key is scoped to tfstate-sandbox only. Run bootstrap-minio.sh to create it.
export MINIO_ENDPOINT="http://192.168.X.X:9000"   # auto-set by make configure
export MINIO_ACCESS_KEY="REPLACE_ME"               # output of scripts/bootstrap-minio.sh
export MINIO_SECRET_KEY="REPLACE_ME"               # output of scripts/bootstrap-minio.sh

# PRODUCTION PROXMOX -- MUST NEVER BE SET HERE
# Production credentials are held by the operator only, never in the dev container.
# export PROXMOX_VE_PROD_ENDPOINT="..."   # DO NOT SET HERE
# export PROXMOX_VE_PROD_API_TOKEN="..."  # DO NOT SET HERE
