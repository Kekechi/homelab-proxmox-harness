# Ansible vault file — for project secrets that cannot live in .envrc.
#
# MinIO credentials (minio_root_user / minio_root_password) have moved to .envrc.
# The minio role reads them via lookup('env', 'MINIO_ROOT_USER') at runtime.
#
# Use this file for future secrets that Ansible roles need encrypted at rest
# (e.g. external API keys, TLS certificates, SMTP passwords).
#
# To create:
#   cp vault.yml.example vault.yml
#   # fill in values
#   ansible-vault encrypt vault.yml
#
# The vault password lives in ANSIBLE_VAULT_PASSWORD in .envrc,
# read at runtime by ansible/vault-pass.sh.
# vault.yml is gitignored — never commit the unencrypted file.
