# MinIO environment file — managed by Ansible, do not edit manually.
# Credentials come from MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in .envrc.
MINIO_ROOT_USER={{ lookup('env', 'MINIO_ROOT_USER') }}
MINIO_ROOT_PASSWORD={{ lookup('env', 'MINIO_ROOT_PASSWORD') }}
MINIO_VOLUMES={{ minio_data_dir }}
{% if minio_tls_enabled | default(false) %}
MINIO_OPTS="--console-address :{{ minio_console_port }} --certs-dir {{ minio_certs_dir }}"
MINIO_SERVER_URL=https://{{ minio_domain }}:{{ minio_port }}
{% else %}
MINIO_OPTS="--console-address :{{ minio_console_port }}"
{% endif %}
