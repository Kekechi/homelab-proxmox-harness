# Production environment configuration
# Copy to config/production.yml and fill in your values.
# Run `make configure ENV=production` after editing.
# WARNING: Production applies are blocked from the dev container.
# `make plan ENV=production` generates production.tfplan for operator review.
# The operator applies this plan manually from their workstation.

environment: production
domain_name: "lab.example.com"              # used in Terraform DNS output hints only

ssh:
  public_key: "ssh-ed25519 AAAAC3... your-key-comment"
  default_user: ubuntu

infrastructure:
  dns_server: ""                           # DNS server IP pushed to all LXC/VM resolv.conf via Terraform.
                                           # Phase 1-2: set to router IP. Phase 3+: switch to DNSdist IP.
                                           # Leave empty to inherit from Proxmox host defaults.
  proxmox:
    ip: "192.168.X.X"
    port: 8006
    insecure: true
  nodes:
    pve1:
      ip: "192.168.X.X"   # Node management IP — added to Squid allowlist
  # For multi-node clusters, uncomment and add additional nodes:
  #   pve2:
  #     ip: "192.168.X.X"
  #   pve3:
  #     ip: "192.168.X.X"
  networks:
    mgmt:
      bridge: vmbr0                        # Management VNet bridge (replace with your bridge name)
      cidr: "X.X.X.X/24"                  # Management VLAN subnet — MUST use CIDR notation; bare IPs rejected
      gateway: "X.X.X.X"                  # Management VLAN gateway
      vlan_id: null                        # null when Proxmox SDN VNets handle VLAN tagging; set an integer for NIC-level tagging
    lan:
      bridge: vmbr1                        # LAN VNet bridge (replace with your bridge name)
      cidr: "X.X.X.X/24"                  # LAN subnet — MUST use CIDR notation
      gateway: "X.X.X.X"                  # LAN gateway
      vlan_id: null                        # null when Proxmox SDN VNets handle VLAN tagging; set an integer for NIC-level tagging
  # No default_network — every service must declare its network explicitly.
  # This prevents accidental placement on the wrong network in production.
  storage:
    datastore_id: local-lvm
    cloudinit_datastore_id: local-lvm     # Directory storage with Snippets content type enabled
    lxc_template_file_id: "local:vztmpl/debian-13-standard_13.0-1_amd64.tar.zst"  # verify with: pveam available --section system | grep debian
    # Cluster setups: use "nfs-shared:vztmpl/debian-13-standard_13.0-1_amd64.tar.zst"

terraform:
  pool_id: ""                              # Production resources are not pool-scoped
  vm_id_range_start: 100                   # Production IDs start lower than sandbox (200)
  clone_template_id: 0
  state_bucket: tfstate-production         # Separate state bucket from sandbox

services:
  minio:
    node: pve1
    ip: "X.X.X.X"                         # MinIO server IP (bare IP, no prefix)
    port: 9000
    ansible_user: root
    hostname: minio-server
    fqdn: "minio.lab.example.com"          # FQDN for TLS cert and MINIO_SERVER_URL; required when tls: true
    tls: true                              # Enable TLS via step-ca ACME; set false for plain HTTP
    network: mgmt                          # Which named network this service is on
    # dns_name: storage        # optional: override DNS label (default: service key "minio")
    # dns_ttl: 300             # optional: per-record TTL in seconds (default: 3600)
    # dns: false               # optional: set to false to exclude from DNS record generation
  pki:
    enabled: false                         # Set true to deploy Issuing CA LXC + Root CA VM (Phase 4)
    root_ca:
      node: pve1
      ip: "X.X.X.X/24"                    # CIDR notation required — Terraform uses prefix for cloud-init
      vm_id: 101
      ansible_user: debian
      hostname: root-ca
      ca_name: "Homelab Root CA"           # CN written into the root certificate
      cloud_init_template_id: 9000         # VMID of cloud-init template — operator runs scripts/setup-vm-template.sh once on Proxmox host
      # Cross-node clone note: template must be registered on the same node as root_ca.node.
      # If template was created on a different node, migrate it first (GUI: right-click → Migrate).
      # Disk stays on NFS — migration only moves the .conf, completes in seconds.
      network: mgmt
    issuing_ca:
      node: pve1
      ip: "X.X.X.X/24"
      ct_id: 102
      ansible_user: root
      hostname: issuing-ca
      ca_name: "Homelab Issuing CA"        # CN written into the intermediate certificate
      network: mgmt
  dns:
    enabled: false                         # Set true to deploy dns-auth + dns-dist LXCs (Phase 3)
    auth:
      node: pve1
      ip: "X.X.X.X/24"                    # CIDR notation required — management VLAN IPs
      ct_id: 103
      ansible_user: root
      hostname: dns-auth
      network: mgmt
      dns_name: dns-auth        # DNS A record label; default would be "auth" (subkey) which is ambiguous
    dist:
      node: pve1
      ip: "X.X.X.X/24"                    # CIDR notation required — management VLAN IPs
      ct_id: 104
      ansible_user: root
      hostname: dns-dist
      network: mgmt
      dns_name: dns-dist        # DNS A record label; default would be "dist" which is ambiguous
      # dns: false              # optional: set to false to exclude this host from DNS record generation entirely
      # dns_ttl: 300            # optional: override TTL for this host's A record (default 3600)
      # client_cidrs:           # optional: CIDRs added to DNSdist ACL beyond the management subnet
      #   - "X.X.X.X/24"      # e.g. LAN VLAN — add any network whose clients should resolve via DNSdist
  nexus:
    enabled: false                         # Set true to deploy Nexus Repository CE LXC (Phase 2)
    node: pve1
    ip: "X.X.X.X/24"                  # CIDR notation required — Terraform uses prefix for cloud-init
    ct_id: 105                         # must not conflict with existing containers
    ansible_user: root
    hostname: nexus-server
    fqdn: "nexus.lab.example.com"      # FQDN for TLS cert and nginx server_name
    network: mgmt
    apt_proxy_repos:
      # --- IaC-required: do not remove ---
      - name: apt-proxy-trixie
        remote_url: "http://deb.debian.org/debian"
        distribution: trixie
      - name: apt-proxy-trixie-security
        remote_url: "http://security.debian.org/debian-security"
        distribution: trixie-security
      - name: apt-proxy-trixie-updates
        remote_url: "http://deb.debian.org/debian"
        distribution: trixie-updates
      - name: apt-proxy-smallstep
        remote_url: "https://packages.smallstep.com/stable/debian"
        distribution: debs
        flat: true
      - name: apt-proxy-powerdns-auth-50
        remote_url: "https://repo.powerdns.com/debian"
        distribution: trixie-auth-50
      - name: apt-proxy-powerdns-rec-54
        remote_url: "https://repo.powerdns.com/debian"
        distribution: trixie-rec-54
      - name: apt-proxy-dnsdist-21
        remote_url: "https://repo.powerdns.com/debian"
        distribution: trixie-dnsdist-21
      # --- Optional: add when PVE nodes use Nexus as APT source ---
      - name: apt-proxy-proxmox-pve
        remote_url: "http://download.proxmox.com/debian/pve"
        distribution: trixie
      - name: apt-proxy-proxmox-ceph-squid
        remote_url: "http://download.proxmox.com/debian/ceph-squid"
        distribution: trixie
    raw_hosted_repos:
      - name: splunkbase               # Splunk app packages (.tgz) — operator uploads post-Phase-1-step-1

  log_server:
    enabled: false                         # Set true to deploy OTel Collector log aggregation LXC
    node: pve1
    ip: "X.X.X.X/24"                  # CIDR notation required — Terraform uses prefix for cloud-init
    ct_id: 106                         # must not conflict with existing containers (101–105 occupied)
    ansible_user: root
    hostname: log-server
    network: mgmt

  splunk:
    enabled: false                         # Set true to deploy Splunk Enterprise VM (hackathon lifecycle)
    node: pve1
    ip: "X.X.X.X/24"                  # CIDR notation required — Terraform uses prefix for cloud-init
    vm_id: 107                         # must not conflict (101–106 occupied)
    ansible_user: ubuntu               # Ubuntu 24.04 default user
    hostname: splunk-server
    cloud_init_template_id: 9001       # VMID of Ubuntu 24.04 cloud-init template — operator creates pre-phase
    network: mgmt
    # hec_port: 8088                  # optional: Splunk HEC ingest port (default 8088); used to emit otelcol_splunk_hec_url

# Future services on LAN:
# services:
#   kubernetes:
#     ip: "X.X.X.X"
#     network: lan

hosts:
  production:
    # production-vm-01:
    #   ansible_host: X.X.X.X
    #   ansible_user: ubuntu
