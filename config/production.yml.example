# Production environment configuration
# Copy to config/production.yml and fill in your values.
# Run `make configure ENV=production` after editing.
# WARNING: Production applies are blocked from the dev container.
# `make plan ENV=production` generates production.tfplan for operator review.
# The operator applies this plan manually from their workstation.

environment: production
domain_name: "lab.example.com"              # used in Terraform DNS output hints only

ssh:
  public_key: "ssh-ed25519 AAAAC3... your-key-comment"
  default_user: ubuntu

infrastructure:
  proxmox:
    ip: "192.168.X.X"
    port: 8006
    node: pve
    insecure: true
  network:
    bridge: vmbr0
    vlan_id: null                          # null = untagged (adjust for your production network)
    cidr: "192.168.X.0/24"                # Production subnet — MUST use CIDR notation (e.g. /24); bare IPs rejected
  storage:
    datastore_id: local-lvm
    cloudinit_datastore_id: local-lvm     # Directory storage with Snippets content type enabled

terraform:
  pool_id: ""                              # Production resources are not pool-scoped
  vm_id_range_start: 100                   # Production IDs start lower than sandbox (200)
  clone_template_id: 0
  state_bucket: tfstate-production         # Separate state bucket from sandbox

services:
  minio:
    ip: "192.168.X.X"                    # MinIO server IP (bare IP, no prefix)
    port: 9000
    ansible_user: root
    hostname: minio-server
    fqdn: "minio.lab.example.com"        # FQDN for TLS cert and MINIO_SERVER_URL; required when tls: true
    tls: true                            # Enable TLS via step-ca ACME; set false for plain HTTP
    # dns_name: storage        # optional: override DNS label (default: service key "minio")
    # dns_ttl: 300             # optional: per-record TTL in seconds (default: 3600)
    # dns: false               # optional: set to false to exclude from DNS record generation
  pki:
    root_ca:
      ip: "192.168.X.X/24"               # CIDR notation required — Terraform uses prefix for cloud-init
      gateway: "192.168.X.1"
      vm_id: 101
      ansible_user: debian
      hostname: root-ca
      cloud_init_template_id: 9000        # VMID of cloud-init template — operator runs scripts/setup-vm-template.sh once on Proxmox host
    issuing_ca:
      ip: "192.168.X.X/24"
      gateway: "192.168.X.1"
      ct_id: 102
      ansible_user: root
      hostname: issuing-ca
      lxc_template_file_id: "local:vztmpl/debian-13-standard_13.0-1_amd64.tar.zst"  # verify with: pveam available --section system | grep debian
  dns:
    auth:
      ip: ""                                  # CIDR notation required (e.g. 192.168.X.103/24) — management VLAN IPs TBD
      gateway: ""
      ct_id: 103
      ansible_user: root
      hostname: dns-auth
    dist:
      ip: ""                                  # CIDR notation required (e.g. 192.168.X.104/24) — management VLAN IPs TBD
      gateway: ""
      ct_id: 104
      ansible_user: root
      hostname: dns-dist
      # dns: false             # optional: set to false to exclude this host from DNS record generation
      # client_cidrs:          # optional: CIDRs added to DNSdist ACL beyond the production subnet
      #   - "192.168.X.0/24"  # e.g. LAN VLAN — add any network whose clients should resolve via DNSdist

hosts:
  production:
    # production-vm-01:
    #   ansible_host: 192.168.X.X
    #   ansible_user: ubuntu
