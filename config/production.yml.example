# Production environment configuration
# Copy to config/production.yml and fill in your values.
# Run `make configure ENV=production` after editing.
# WARNING: Production applies are blocked from the dev container.
# `make plan ENV=production` generates production.tfplan for operator review.
# The operator applies this plan manually from their workstation.

environment: production
domain_name: "lab.example.com"              # used in Terraform DNS output hints only

ssh:
  public_key: "ssh-ed25519 AAAAC3... your-key-comment"
  default_user: ubuntu

infrastructure:
  proxmox:
    ip: "192.168.X.X"
    port: 8006
    node: pve
    insecure: true
  networks:
    mgmt:
      bridge: vmbr0                        # Management VNet bridge (replace with your bridge name)
      cidr: "X.X.X.X/24"                  # Management VLAN subnet — MUST use CIDR notation; bare IPs rejected
      gateway: "X.X.X.X"                  # Management VLAN gateway
      vlan_id: null                        # null when Proxmox SDN VNets handle VLAN tagging; set an integer for NIC-level tagging
    lan:
      bridge: vmbr1                        # LAN VNet bridge (replace with your bridge name)
      cidr: "X.X.X.X/24"                  # LAN subnet — MUST use CIDR notation
      gateway: "X.X.X.X"                  # LAN gateway
      vlan_id: null                        # null when Proxmox SDN VNets handle VLAN tagging; set an integer for NIC-level tagging
  # No default_network — every service must declare its network explicitly.
  # This prevents accidental placement on the wrong network in production.
  storage:
    datastore_id: local-lvm
    cloudinit_datastore_id: local-lvm     # Directory storage with Snippets content type enabled
    lxc_template_file_id: "local:vztmpl/debian-13-standard_13.0-1_amd64.tar.zst"  # verify with: pveam available --section system | grep debian

terraform:
  pool_id: ""                              # Production resources are not pool-scoped
  vm_id_range_start: 100                   # Production IDs start lower than sandbox (200)
  clone_template_id: 0
  state_bucket: tfstate-production         # Separate state bucket from sandbox

services:
  minio:
    ip: "X.X.X.X"                         # MinIO server IP (bare IP, no prefix)
    port: 9000
    ansible_user: root
    hostname: minio-server
    fqdn: "minio.lab.example.com"          # FQDN for TLS cert and MINIO_SERVER_URL; required when tls: true
    tls: true                              # Enable TLS via step-ca ACME; set false for plain HTTP
    network: mgmt                          # Which named network this service is on
    # dns_name: storage        # optional: override DNS label (default: service key "minio")
    # dns_ttl: 300             # optional: per-record TTL in seconds (default: 3600)
    # dns: false               # optional: set to false to exclude from DNS record generation
  pki:
    root_ca:
      ip: "X.X.X.X/24"                    # CIDR notation required — Terraform uses prefix for cloud-init
      vm_id: 101
      ansible_user: debian
      hostname: root-ca
      cloud_init_template_id: 9000         # VMID of cloud-init template — operator runs scripts/setup-vm-template.sh once on Proxmox host
      network: mgmt
    issuing_ca:
      ip: "X.X.X.X/24"
      ct_id: 102
      ansible_user: root
      hostname: issuing-ca
      network: mgmt
  dns:
    auth:
      ip: "X.X.X.X/24"                    # CIDR notation required — management VLAN IPs
      ct_id: 103
      ansible_user: root
      hostname: dns-auth
      network: mgmt
      dns_name: dns-auth        # DNS A record label; default would be "auth" (subkey) which is ambiguous
    dist:
      ip: "X.X.X.X/24"                    # CIDR notation required — management VLAN IPs
      ct_id: 104
      ansible_user: root
      hostname: dns-dist
      network: mgmt
      dns_name: dns-dist        # DNS A record label; default would be "dist" which is ambiguous
      # dns: false              # optional: set to false to exclude this host from DNS record generation entirely
      # dns_ttl: 300            # optional: override TTL for this host's A record (default 3600)
      # client_cidrs:           # optional: CIDRs added to DNSdist ACL beyond the management subnet
      #   - "X.X.X.X/24"      # e.g. LAN VLAN — add any network whose clients should resolve via DNSdist
  nexus:
    ip: "X.X.X.X/24"                  # CIDR notation required — Terraform uses prefix for cloud-init
    ct_id: 105                         # must not conflict with existing containers
    ansible_user: root
    hostname: nexus-server
    fqdn: "nexus.lab.example.com"      # FQDN for TLS cert and nginx server_name
    network: mgmt

# Future services on LAN:
# services:
#   kubernetes:
#     ip: "X.X.X.X"
#     network: lan

hosts:
  production:
    # production-vm-01:
    #   ansible_host: X.X.X.X
    #   ansible_user: ubuntu
