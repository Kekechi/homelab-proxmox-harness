# Sandbox environment configuration
# Copy to config/sandbox.yml and fill in your values.
# Run `make configure` after editing to regenerate all downstream config files.
# Secrets (API tokens, MinIO keys, passwords) go in .envrc and ansible vault — NOT here.

environment: sandbox
domain_name: "sandbox.example.com"          # used in Terraform DNS output hints only

ssh:
  public_key: "ssh-ed25519 AAAAC3... your-key-comment"  # SSH public key injected via cloud-init
  default_user: ubuntu                   # Default ansible_user for VMs

infrastructure:
  dns_server: ""                           # DNS server IP pushed to all LXC/VM resolv.conf via Terraform.
                                           # Phase 1-2: set to router IP. Phase 3+: switch to DNSdist IP.
                                           # Leave empty to inherit from Proxmox host defaults.
  proxmox:
    ip: "192.168.X.X"                    # Proxmox host IP
    port: 8006                           # Proxmox API port
    insecure: true                       # true = accept self-signed TLS cert
  nodes:
    pve1:
      ip: "192.168.X.X"   # Node management IP — added to Squid allowlist
  # For multi-node clusters, uncomment and add additional nodes:
  #   pve2:
  #     ip: "192.168.X.X"
  #   pve3:
  #     ip: "192.168.X.X"
  networks:
    sandbox:
      bridge: vmbr0                      # Replace with your Proxmox VNet bridge name
      cidr: "192.168.X.0/24"            # Sandbox subnet — MUST use CIDR notation (e.g. /24); bare IPs rejected
      gateway: "192.168.X.1"            # Default gateway for all sandbox VMs/LXCs
      vlan_id: null                      # null when Proxmox SDN VNets handle VLAN tagging; set an integer for NIC-level tagging
  default_network: sandbox               # All services inherit this network; omit in production to require explicit placement
  storage:
    datastore_id: local-lvm             # Proxmox storage ID for VM/LXC disks
    cloudinit_datastore_id: local-lvm   # Directory storage with Snippets content type enabled
    lxc_template_file_id: "local:vztmpl/debian-13-standard_13.0-1_amd64.tar.zst"  # verify with: pveam available --section system | grep debian
    # Cluster setups: use "nfs-shared:vztmpl/debian-13-standard_13.0-1_amd64.tar.zst"

terraform:
  pool_id: sandbox                       # Proxmox resource pool (operator creates this)
  vm_id_range_start: 200                 # First VM/LXC ID to use in sandbox
  clone_template_id: 0                   # Template VM ID to clone from (0 = create from scratch)
  state_bucket: tfstate-sandbox          # MinIO bucket for Terraform state

# Services deployed to the homelab.
# Each service is defined once here; make configure auto-derives the Ansible inventory
# group, Squid allowlist CIDR, and endpoint URLs — no duplication needed.
services:
  minio:
    node: pve1
    ip: "192.168.X.X"                    # MinIO server IP (bare IP, no prefix)
    port: 9000
    ansible_user: root
    hostname: minio-server               # Ansible inventory hostname
    fqdn: "minio.sandbox.example.com"    # FQDN for TLS cert and MINIO_SERVER_URL; required when tls: true (generator exits with error if missing)
    tls: true                            # Enable TLS via step-ca ACME; set false for plain HTTP
    network: sandbox                     # Which named network this service is on
    # dns_name: storage        # optional: override DNS label (default: service key "minio")
    # dns_ttl: 300             # optional: per-record TTL in seconds (default: 3600)
    # dns: false               # optional: set to false to exclude from DNS record generation
  pki:
    enabled: false                         # Set true to deploy Issuing CA LXC + Root CA VM (Phase 4)
    root_ca:
      node: pve1
      ip: "192.168.X.X/24"              # CIDR notation required — Terraform uses prefix for cloud-init
      vm_id: 201                         # must not conflict with existing VMs
      ansible_user: debian
      hostname: root-ca
      ca_name: "Homelab Root CA"         # CN written into the root certificate
      cloud_init_template_id: 9000       # VMID of Debian cloud-init template — operator runs scripts/setup-vm-template.sh once on Proxmox host
      # Cross-node clone note: template must be registered on the same node as root_ca.node.
      # If template was created on a different node, migrate it first (GUI: right-click → Migrate).
      # Disk stays on NFS — migration only moves the .conf, completes in seconds.
    issuing_ca:
      node: pve1
      ip: "192.168.X.X/24"
      ct_id: 202
      ansible_user: root
      hostname: issuing-ca
      ca_name: "Homelab Issuing CA"      # CN written into the intermediate certificate
  dns:
    enabled: false                         # Set true to deploy dns-auth + dns-dist LXCs (Phase 3)
    auth:
      node: pve1
      ip: "192.168.X.X/24"
      ct_id: 203
      ansible_user: root
      hostname: dns-auth
      dns_name: dns-auth        # DNS A record label; default would be "auth" (subkey) which is ambiguous
    dist:
      node: pve1
      ip: "192.168.X.X/24"
      ct_id: 204
      ansible_user: root
      hostname: dns-dist
      dns_name: dns-dist        # DNS A record label; default would be "dist" which is ambiguous
      # dns: false              # optional: set to false to exclude this host from DNS record generation entirely
      # dns_ttl: 300            # optional: override TTL for this host's A record (default 3600)
      # client_cidrs:           # optional: CIDRs added to DNSdist ACL beyond the sandbox VLAN
      #   - "192.168.X.0/24"   # e.g. LAN VLAN — add any network whose clients should resolve via DNSdist
  nexus:
    enabled: false                         # Set true to deploy Nexus Repository CE LXC (Phase 2)
    node: pve1
    ip: "192.168.X.X/24"              # CIDR notation required — Terraform uses prefix for cloud-init
    ct_id: 205                         # must not conflict with existing containers
    ansible_user: root
    hostname: nexus-server
    fqdn: "nexus.sandbox.example.com"  # FQDN for TLS cert and nginx server_name
    tls: false                         # Set true (Phase 5) to issue cert from internal CA and enable nginx HTTPS
    network: sandbox
    apt_proxy_repos:
      # --- IaC-required: do not remove ---
      - name: apt-proxy-trixie
        remote_url: "http://deb.debian.org/debian"
        distribution: trixie
      - name: apt-proxy-trixie-security
        remote_url: "http://security.debian.org/debian-security"
        distribution: trixie-security
      - name: apt-proxy-trixie-updates
        remote_url: "http://deb.debian.org/debian"
        distribution: trixie-updates
      - name: apt-proxy-smallstep
        remote_url: "https://packages.smallstep.com/stable/debian"
        distribution: debs
        flat: true
      - name: apt-proxy-powerdns-auth-50
        remote_url: "https://repo.powerdns.com/debian"
        distribution: trixie-auth-50
      - name: apt-proxy-powerdns-rec-54
        remote_url: "https://repo.powerdns.com/debian"
        distribution: trixie-rec-54
      - name: apt-proxy-dnsdist-21
        remote_url: "https://repo.powerdns.com/debian"
        distribution: trixie-dnsdist-21
      # --- Optional: add when PVE nodes use Nexus as APT source ---
      - name: apt-proxy-proxmox-pve
        remote_url: "http://download.proxmox.com/debian/pve"
        distribution: trixie
      - name: apt-proxy-proxmox-ceph-squid
        remote_url: "http://download.proxmox.com/debian/ceph-squid"
        distribution: trixie

# Ad-hoc hosts not covered by a named service above.
# Each top-level key is an Ansible group; hosts within are inventory entries.
hosts:
  sandbox:
    # sandbox-vm-01:
    #   ansible_host: 192.168.X.X
