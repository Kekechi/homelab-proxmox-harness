# Sandbox environment configuration
# Copy to config/sandbox.yml and fill in your values.
# Run `make configure` after editing to regenerate all downstream config files.
# Secrets (API tokens, MinIO keys, passwords) go in .envrc and ansible vault — NOT here.

environment: sandbox
domain_name: "sandbox.example.com"          # used in Terraform DNS output hints only

ssh:
  public_key: "ssh-ed25519 AAAAC3... your-key-comment"  # SSH public key injected via cloud-init
  default_user: ubuntu                   # Default ansible_user for VMs

infrastructure:
  proxmox:
    ip: "192.168.X.X"                    # Proxmox host IP
    port: 8006                           # Proxmox API port
    node: pve                            # Proxmox node name (run: pvesh get /nodes)
    insecure: true                       # true = accept self-signed TLS cert
  network:
    bridge: vmbr0                        # Network bridge for VMs/LXCs
    vlan_id: 50                          # VLAN tag for sandbox network (null = untagged)
    cidr: "192.168.X.0/24"              # Sandbox VLAN subnet — MUST use CIDR notation
  storage:
    datastore_id: local-lvm             # Proxmox storage ID for VM/LXC disks
    cloudinit_datastore_id: local-lvm   # Directory storage with Snippets content type enabled

terraform:
  pool_id: sandbox                       # Proxmox resource pool (operator creates this)
  vm_id_range_start: 200                 # First VM/LXC ID to use in sandbox
  clone_template_id: 0                   # Template VM ID to clone from (0 = create from scratch)
  state_bucket: tfstate-sandbox          # MinIO bucket for Terraform state

# Services deployed to the homelab.
# Each service is defined once here; make configure auto-derives the Ansible inventory
# group, Squid allowlist CIDR, and endpoint URLs — no duplication needed.
services:
  minio:
    ip: "192.168.X.X"                    # MinIO server IP (bare IP, no prefix)
    port: 9000
    ansible_user: root
    hostname: minio-server               # Ansible inventory hostname
    fqdn: "minio.sandbox.example.com"    # FQDN for TLS cert and MINIO_SERVER_URL; required when tls: true (generator exits with error if missing)
    tls: true                            # Enable TLS via step-ca ACME; set false for plain HTTP
  pki:
    root_ca:
      ip: "192.168.X.X/24"              # CIDR notation required — Terraform uses prefix for cloud-init
      gateway: "192.168.X.1"
      vm_id: 201                         # must not conflict with existing VMs
      ansible_user: debian
      hostname: root-ca
      cloud_init_template_id: 9000       # VMID of Debian cloud-init template (from setup-vm-template.sh)
    issuing_ca:
      ip: "192.168.X.X/24"
      gateway: "192.168.X.1"
      ct_id: 202
      ansible_user: root
      hostname: issuing-ca
      lxc_template_file_id: "local:vztmpl/debian-13-standard_13.0-1_amd64.tar.zst"  # verify with: pveam available --section system | grep debian

# Ad-hoc hosts not covered by a named service above.
# Each top-level key is an Ansible group; hosts within are inventory entries.
hosts:
  sandbox:
    # sandbox-vm-01:
    #   ansible_host: 192.168.X.X
