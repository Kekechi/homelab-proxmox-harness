# ============================================================
# Centralized config — gitignored; only *.yml.example committed
# ============================================================
config/*.yml
!config/*.yml.example

# ============================================================
# Secrets — never commit
# ============================================================
.envrc
.envrc.new
*.pem
*.key
id_rsa
id_ed25519
vault_pass
.vault_pass
*.secrets
secrets.yml

# ============================================================
# Terraform
# ============================================================
**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfplan
crash.log
crash.*.log

# terraform.tfvars contains secrets/IPs — use .tfvars.example instead
*.tfvars
!*.tfvars.example

# Makefile env fragment — generated by scripts/generate-configs.py
.env.mk

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ============================================================
# Ansible
# ============================================================
*.retry
ansible/.vault_pass
# Generated single inventory file
ansible/inventory/hosts.yml
# Vault-encrypted secrets (flat structure — no env subdirs)
ansible/inventory/group_vars/all/vault.yml
# Legacy pattern kept for backwards compatibility during transition
ansible/inventory/*/group_vars/all/vault.yml

# ============================================================
# Dev tooling
# ============================================================
.direnv/
.DS_Store
.idea/
.vscode/settings.json
*.swp
*.swo
*~

# ============================================================
# OS
# ============================================================
Thumbs.db
