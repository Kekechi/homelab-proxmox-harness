# ============================================================
# Centralized config — gitignored; only *.yml.example committed
# ============================================================
config/*.yml
!config/*.yml.example

# ============================================================
# Secrets — never commit
# ============================================================
.envrc
.envrc.new
*.pem
*.key
id_rsa
id_ed25519
.ssh/
*.secrets
secrets.yml

# ============================================================
# Terraform
# ============================================================
**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfplan
crash.log
crash.*.log

# terraform.tfvars contains secrets/IPs — use .tfvars.example instead
*.tfvars
!*.tfvars.example

# Makefile env fragment — generated by scripts/generate-configs.py
.env.mk

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ============================================================
# Ansible
# ============================================================
*.retry
ansible/.vault_pass
# Generated single inventory file
ansible/inventory/hosts.yml
# Vault-encrypted secrets (flat structure — no env subdirs)
ansible/inventory/group_vars/all/vault.yml
# Legacy pattern kept for backwards compatibility during transition
ansible/inventory/*/group_vars/all/vault.yml
# group_vars vars files may contain env-specific hostnames, IPs, or internal
# names. Ignore all of them by default — only *.yml.example files are committed.
# This covers current and future roles without per-directory gitignore entries.
ansible/inventory/group_vars/**/*.yml
!ansible/inventory/group_vars/**/*.yml.example
# Explicit carve-outs for files that ARE safe to commit (shared defaults, no env data)
!ansible/inventory/group_vars/all/step_ca.yml

# PKI staging — certs and CSRs fetched from CA hosts during ansible runs.
# Persists across container rebuilds (workspace volume). Never contains private keys.
.pki/

# Generated by make configure — contains network CIDRs from config YAML
.devcontainer/squid/allowed-cidrs.conf

# ============================================================
# Python
# ============================================================
__pycache__/
*.pyc
*.pyo

# ============================================================
# Dev tooling
# ============================================================
.direnv/
.DS_Store
.idea/
.vscode/settings.json
*.swp
*.swo
*~

# ============================================================
# Local working docs (full-detail, not for public repo)
# ============================================================
docs/design/splunk-hackathon-project.md

# ============================================================
# Local Config
# ============================================================
*.local
*.local.json

# ============================================================
# OS
# ============================================================
Thumbs.db
